{
  "info": {
    "name": "Payment Checkout Challenge",
    "_postman_id": "4b64b812-04c5-4cc0-b747-5d6ea0f9d0a0",
    "description": "Postman collection for the current product and transaction API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "productId",
      "value": "replace-with-product-id"
    },
    {
      "key": "transactionId",
      "value": "replace-with-transaction-id"
    },
    {
      "key": "customerId",
      "value": "replace-with-customer-id"
    },
    {
      "key": "customerEmail",
      "value": "john@example.com"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1,\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"john@example.com\",\n  \"customerPhone\": \"3001234567\",\n  \"deliveryAddress\": \"Calle 123\",\n  \"deliveryCity\": \"Bogota\",\n  \"deliveryDepartment\": \"Cundinamarca\",\n  \"deliveryPostalCode\": \"110111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions"
              ]
            }
          }
        },
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardToken\": \"replace-with-card-token\",\n  \"acceptanceToken\": \"replace-with-acceptance-token\",\n  \"customerEmail\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/pay",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}",
                "pay"
              ]
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get Customer By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "{{customerId}}"
              ]
            }
          }
        },
        {
          "name": "Get Customer By Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/email/{{customerEmail}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "email",
                "{{customerEmail}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Deliveries",
      "item": [
        {
          "name": "Get Delivery By Transaction Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/transaction/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "deliveries",
                "transaction",
                "{{transactionId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}